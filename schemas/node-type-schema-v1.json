{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/newo-ether/blender-mcp/schemas/node-type-schema-v1.json",
  "title": "Blender MCP runtime node-type schema v1",
  "type": "object",
  "required": [
    "schema", "blender_version", "tree_type", "owner_kind", "detail",
    "node_type", "label", "description", "properties", "inputs", "outputs"
  ],
  "properties": {
    "schema": {"const": "blender-node-type-schema/1"},
    "blender_version": {"type": "array", "minItems": 3, "maxItems": 3, "items": {"type": "integer"}},
    "blender_version_string": {"type": "string"},
    "build_hash": {"type": ["string", "null"]},
    "tree_type": {"enum": ["GeometryNodeTree", "ShaderNodeTree", "CompositorNodeTree"]},
    "owner_kind": {"enum": ["MATERIAL", "WORLD", "LIGHT", "SCENE", "NODE_GROUP"]},
    "detail": {"enum": ["compact", "full"]},
    "node_type": {"type": "string"},
    "label": {"type": "string"},
    "description": {"type": "string"},
    "properties": {"type": "array", "items": {"type": "object"}},
    "inputs": {"type": "array", "items": {"type": "object"}},
    "outputs": {"type": "array", "items": {"type": "object"}},
    "dynamic_items": {"type": "array", "items": {"type": "object"}},
    "special_structures": {"type": "array", "items": {"type": "object"}}
  },
  "additionalProperties": false
}
