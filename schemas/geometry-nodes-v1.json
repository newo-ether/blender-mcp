{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ahujasid/blender-mcp/schemas/geometry-nodes-v1.json",
  "title": "Blender MCP Geometry Nodes snapshot v1",
  "type": "object",
  "required": ["schema", "blender_version", "view", "tree", "scope", "revision", "users", "stats"],
  "properties": {
    "schema": {"const": "blender-geometry-nodes/1"},
    "blender_version": {
      "type": "array",
      "prefixItems": [
        {"type": "integer"},
        {"type": "integer"},
        {"type": "integer"}
      ],
      "minItems": 3,
      "maxItems": 3
    },
    "view": {"enum": ["semantic", "layout", "all"]},
    "revision": {
      "description": "Full all-view source revision, independent of export view and subgraph scope",
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "tree": {"$ref": "#/$defs/tree"},
    "scope": {
      "type": "object",
      "required": ["kind", "requested_nodes", "neighbor_depth", "included_nodes", "content_revision"],
      "properties": {
        "kind": {"enum": ["full", "subgraph"]},
        "requested_nodes": {"type": "array", "items": {"type": "string"}},
        "neighbor_depth": {"type": "integer", "minimum": 0, "maximum": 5},
        "included_nodes": {"type": "array", "items": {"type": "string"}},
        "content_revision": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}
      },
      "additionalProperties": false
    },
    "users": {"type": "array", "items": {"$ref": "#/$defs/user"}},
    "stats": {
      "type": "object",
      "required": ["node_count", "link_count", "interface_item_count"],
      "properties": {
        "node_count": {"type": "integer", "minimum": 0},
        "link_count": {"type": "integer", "minimum": 0},
        "interface_item_count": {"type": "integer", "minimum": 0},
        "total_node_count": {"type": "integer", "minimum": 0},
        "total_link_count": {"type": "integer", "minimum": 0},
        "json_bytes": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "typedValue": {
      "description": "A JSON primitive/list/map or a typed Blender value/reference"
    },
    "socket": {
      "type": "object",
      "required": ["id", "index", "name", "direction", "bl_idname", "enabled", "linked"],
      "properties": {
        "id": {"type": "string"},
        "index": {"type": "integer", "minimum": 0},
        "name": {"type": "string"},
        "identifier": {"type": "string"},
        "direction": {"enum": ["INPUT", "OUTPUT"]},
        "bl_idname": {"type": "string"},
        "enabled": {"type": "boolean"},
        "linked": {"type": "boolean"},
        "multi_input": {"type": "boolean"},
        "default": {"$ref": "#/$defs/typedValue"}
      },
      "additionalProperties": true
    },
    "node": {
      "type": "object",
      "required": ["id", "name", "bl_idname", "properties", "inputs", "outputs"],
      "properties": {
        "id": {"type": "string"},
        "name": {"type": "string"},
        "label": {"type": "string"},
        "bl_idname": {"type": "string"},
        "properties": {"type": "object"},
        "inputs": {"type": "array", "items": {"$ref": "#/$defs/socket"}},
        "outputs": {"type": "array", "items": {"$ref": "#/$defs/socket"}},
        "layout": {
          "type": "object",
          "properties": {
            "location": {"type": "array", "minItems": 2, "maxItems": 2},
            "width": {"type": "number"},
            "height": {"type": "number"},
            "parent": {"type": ["string", "null"]}
          }
        }
      },
      "additionalProperties": true
    },
    "link": {
      "type": "object",
      "required": ["from_node", "from_socket", "to_node", "to_socket"],
      "properties": {
        "from_node": {"type": "string"},
        "from_socket": {"type": "string"},
        "to_node": {"type": "string"},
        "to_socket": {"type": "string"},
        "multi_input_sort_id": {"type": "integer"}
      },
      "additionalProperties": false
    },
    "interfaceItem": {
      "type": "object",
      "required": ["item_type", "identifier", "name"],
      "properties": {
        "item_type": {"enum": ["PANEL", "SOCKET"]},
        "identifier": {"type": "string"},
        "name": {"type": "string"},
        "parent": {"type": ["string", "null"]},
        "in_out": {"enum": ["INPUT", "OUTPUT"]},
        "socket_type": {"type": "string"},
        "default": {"$ref": "#/$defs/typedValue"}
      },
      "additionalProperties": true
    },
    "tree": {
      "type": "object",
      "required": ["name", "bl_idname", "editable", "library", "interface", "nodes", "links"],
      "properties": {
        "name": {"type": "string"},
        "bl_idname": {"const": "GeometryNodeTree"},
        "editable": {"type": "boolean"},
        "library": {"type": ["string", "null"]},
        "interface": {"type": "array", "items": {"$ref": "#/$defs/interfaceItem"}},
        "nodes": {
          "type": "object",
          "additionalProperties": {"$ref": "#/$defs/node"}
        },
        "links": {"type": "array", "items": {"$ref": "#/$defs/link"}}
      },
      "additionalProperties": false
    },
    "user": {
      "type": "object",
      "required": ["kind", "name"],
      "properties": {
        "kind": {"enum": ["MODIFIER", "GROUP_NODE"]},
        "name": {"type": "string"},
        "object": {"type": "string"},
        "modifier": {"type": "string"},
        "tree": {"type": "string"},
        "node": {"type": "string"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
